---
import { Image } from 'astro:assets';
import logoWhite from '../images/logo-white.png';
import { eventInfo } from '../data/event';

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ted-ink)] text-neutral-200">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 md:grid-cols-3 md:px-8">
    <div>
      <Image
        src={logoWhite}
        alt={`${eventInfo.name} logo`}
        widths={[160, 320]}
        sizes="160px"
        class="h-10 w-auto"
        loading="lazy"
      />
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-neutral-400">
        An independently organized TEDx event in Watford, exploring ideas worth spreading on the
        theme of love.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-white">Explore</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/#about" class="hover:text-white">About the event</a></li>
        <li><a href="/#venue" class="hover:text-white">Venue</a></li>
        <li><a href="/#faq" class="hover:text-white">FAQ</a></li>
        <li><a href="/about" class="hover:text-white">About TED &amp; TEDx</a></li>
        <li>
          <a href={eventInfo.tedxProgramUrl} target="_blank" rel="noopener" class="hover:text-white">
            TEDx program ↗
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-white">Contact</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href={`mailto:${eventInfo.contactEmail}`} class="hover:text-white">
            {eventInfo.contactEmail}
          </a>
        </li>
        <li>
          <a
            href={eventInfo.ticketUrl}
            target="_blank"
            rel="noopener"
            data-luma-action="checkout"
            data-luma-event-id={eventInfo.lumaEventId}
            class="hover:text-white"
          >
            Reserve a spot on Luma ↗
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-neutral-800">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-6 text-xs text-neutral-500 md:flex-row md:items-center md:justify-between md:px-8">
      <p>This independent TEDx event is operated under license from TED.</p>
      <p>© {year} {eventInfo.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
