---
import { eventInfo } from '../data/event';
---

<section
  id="schedule"
  class="bg-[var(--color-ted-ink)] py-20 text-neutral-100 md:py-28"
  aria-labelledby="schedule-heading"
>
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
      Schedule
    </p>
    <h2 id="schedule-heading" class="mt-3 text-4xl font-bold tracking-tight text-white md:text-5xl">
      {eventInfo.displayDate} · {eventInfo.displayTime}
    </h2>

    <div class="mt-10 rounded-2xl border-2 border-dashed border-neutral-700 p-12 text-center">
      <p class="text-2xl font-semibold text-white">Schedule to be announced.</p>
      <p class="mx-auto mt-3 max-w-xl text-neutral-400">
        The full running order — including talks, breaks, and performances — will be published as
        we get closer to the event.
      </p>
    </div>
  </div>
</section>
