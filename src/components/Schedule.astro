---
import { eventInfo } from '../data/event';
import { schedule } from '../data/schedule';
---

<section
  id="schedule"
  class="bg-[var(--color-ted-ink)] py-20 text-neutral-100 md:py-28"
  aria-labelledby="schedule-heading"
>
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
      Schedule
    </p>
    <h2 id="schedule-heading" class="mt-3 text-4xl font-bold tracking-tight text-white md:text-5xl">
      {eventInfo.displayDate} · {eventInfo.displayTime}
    </h2>

    <ol class="mt-12 max-w-3xl">
      {
        schedule.map((item) => (
          <li class="flex items-baseline gap-4 border-t border-neutral-800 py-4 md:gap-8">
            <span class="w-20 shrink-0 font-semibold tabular-nums text-[var(--color-ted-red)]">
              {item.time}
            </span>
            {item.type === 'talk' ? (
              <span class="text-lg font-semibold text-white md:text-xl">{item.title}</span>
            ) : item.type === 'performance' ? (
              <span class="text-lg font-semibold text-white md:text-xl">
                {item.title}
                <span class="ml-2 align-middle text-sm font-medium uppercase tracking-wider text-[var(--color-ted-red)]">
                  Live music
                </span>
              </span>
            ) : (
              <span class="text-lg text-neutral-200 md:text-xl">{item.title}</span>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>
