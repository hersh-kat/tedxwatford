---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items?: FaqItem[];
}

const defaultItems: FaqItem[] = [
  {
    q: 'How do I get tickets?',
    a: 'Tickets are issued through Luma at luma.com/tedxwatford. Spots are limited and subject to approval to ensure a curated, aligned audience experience for the Watford community.',
  },
  {
    q: 'Where exactly is the venue?',
    a: 'Bhaktivedanta Manor, Dharam Marg, Radlett, Watford WD25 8EZ. It is roughly a 15-minute drive from central Watford and well-connected by car and taxi.',
  },
  {
    q: 'What time should I arrive?',
    a: 'Doors open shortly before 4:00 pm. We recommend arriving 30 minutes early to settle in.',
  },
  {
    q: 'Will food be provided?',
    a: 'Details on refreshments will be shared with confirmed attendees by email closer to the event.',
  },
  {
    q: "I haven't received my email — what should I do?",
    a: "Please check your spam/junk folder for emails from us, and add team@tedxwatford.com to your safe senders list so you don't miss any updates. If you still can't find anything, drop us a line.",
  },
  {
    q: 'I have another question.',
    a: 'Email us at team@tedxwatford.com and we will get back to you.',
  },
];

const { items = defaultItems } = Astro.props;
---

<section id="faq" class="bg-neutral-50 py-20 md:py-28" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-4xl px-4 md:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
      FAQ
    </p>
    <h2 id="faq-heading" class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
      Things you might be wondering.
    </h2>

    <div class="mt-10 divide-y divide-neutral-200 rounded-2xl border border-neutral-200 bg-white">
      {
        items.map((item) => (
          <details class="group px-6 py-5">
            <summary class="flex cursor-pointer items-start justify-between gap-4 text-lg font-semibold">
              <span>{item.q}</span>
              <span class="mt-1 text-[var(--color-ted-red)] transition group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 text-neutral-700">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
