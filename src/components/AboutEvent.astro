---
import { eventInfo } from '../data/event';
---

<section
  id="about"
  class="bg-neutral-50 py-20 md:py-28"
  aria-labelledby="about-heading"
>
  <div class="mx-auto grid max-w-6xl gap-12 px-4 md:grid-cols-5 md:px-8">
    <div class="md:col-span-2">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
        About the event
      </p>
      <h2 id="about-heading" class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
        Ideas worth spreading on the theme of love.
      </h2>
    </div>

    <div class="space-y-6 text-lg leading-relaxed text-neutral-700 md:col-span-3">
      <p>{eventInfo.description}</p>
      <p>{eventInfo.longDescription}</p>
      <p>
        This first ever {eventInfo.name} goes beyond a conference. It's an immersive experience
        designed to bring communities together from Watford and beyond, spark meaningful
        conversations, and foster genuine connection around ideas worth spreading.
      </p>
      <p class="text-xl font-semibold text-neutral-900">All you need is love.</p>
    </div>
  </div>
</section>
