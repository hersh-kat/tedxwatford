---
import { eventInfo } from '../data/event';
const { venue } = eventInfo;
---

<section id="venue" class="py-20 md:py-28" aria-labelledby="venue-heading">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 md:grid-cols-2 md:px-8">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
        Venue
      </p>
      <h2 id="venue-heading" class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
        {venue.name}
      </h2>
      <address class="mt-6 not-italic text-lg leading-relaxed text-neutral-700">
        {venue.streetAddress}<br />
        {venue.addressLocality} {venue.postalCode}<br />
        United Kingdom
      </address>
      <a
        href={venue.mapsUrl}
        target="_blank"
        rel="noopener"
        class="mt-6 inline-flex items-center rounded-full border border-neutral-300 px-5 py-2.5 text-sm font-semibold transition hover:border-neutral-900"
      >
        Open in Google Maps ↗
      </a>
    </div>

    <div class="space-y-4 text-lg leading-relaxed text-neutral-700">
      <p>
        {venue.name} is the iconic and historic estate gifted to ISKCON by George Harrison in 1973.
        Set in the rolling Hertfordshire countryside just outside Watford, it's a place steeped in
        the spirit of the music, the message and the moment that inspired our theme.
      </p>
      <p>
        We can't think of a more fitting setting to spend an evening exploring what we all need —
        love.
      </p>
    </div>
  </div>
</section>
