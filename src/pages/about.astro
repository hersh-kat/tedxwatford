---
import BaseLayout from '../layouts/BaseLayout.astro';
import { eventInfo } from '../data/event';

const title = `About ${eventInfo.name}, TEDx and TED`;
const description = `Learn about ${eventInfo.name}, the TEDx program, and TED — the nonprofit dedicated to discovering and spreading ideas worth sharing.`;
---

<BaseLayout title={title} description={description} pathname="/about" includeEventSchema={false}>
  <article class="mx-auto max-w-3xl px-4 py-16 md:px-8 md:py-24">
    <header>
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-ted-red)]">
        About
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight md:text-5xl">
        About {eventInfo.name}, TEDx and TED.
      </h1>
    </header>

    <section class="mt-12 space-y-4 text-lg leading-relaxed text-neutral-700" aria-labelledby="about-event-heading">
      <h2 id="about-event-heading" class="text-2xl font-bold tracking-tight text-neutral-900">
        About {eventInfo.name}
      </h2>
      <p>{eventInfo.description}</p>
      <p>{eventInfo.longDescription}</p>
      <p>
        This first ever {eventInfo.name} goes beyond a conference. It's an immersive experience
        designed to bring communities together from Watford and beyond, spark meaningful
        conversations, and foster genuine connection around ideas worth spreading.
      </p>
      <p>
        Questions? Email us at
        <a href={`mailto:${eventInfo.contactEmail}`} class="font-semibold text-[var(--color-ted-red)] hover:underline">
          {eventInfo.contactEmail}
        </a>.
      </p>
    </section>

    <section class="mt-16 space-y-4 text-lg leading-relaxed text-neutral-700" aria-labelledby="about-team-heading">
      <h2 id="about-team-heading" class="text-2xl font-bold tracking-tight text-neutral-900">
        The team
      </h2>
      <p class="rounded-2xl border-2 border-dashed border-neutral-300 bg-neutral-50 p-6 text-base text-neutral-600">
        Organizer and team bios will be added shortly. {eventInfo.name} is an entirely volunteer
        effort by people who live and work in Watford and the surrounding area.
      </p>
    </section>

    <section class="mt-16 space-y-4 text-lg leading-relaxed text-neutral-700" aria-labelledby="about-tedx-heading">
      <h2 id="about-tedx-heading" class="text-2xl font-bold tracking-tight text-neutral-900">
        About TEDx, x = independently organized event
      </h2>
      <p>
        In the spirit of discovering and spreading ideas, TEDx is a program of local,
        self-organized events that bring people together to share a TED-like experience. At a TEDx
        event, TED Talks video and live speakers combine to spark deep discussion and connection.
        These local, self-organized events are branded TEDx, where x = independently organized TED
        event. The TED Conference provides general guidance for the TEDx program, but individual
        TEDx events are self-organized. (Subject to certain rules and regulations.)
      </p>
      <p>
        <a
          href={eventInfo.tedxProgramUrl}
          target="_blank"
          rel="noopener"
          class="font-semibold text-[var(--color-ted-red)] hover:underline"
        >
          Learn more about the TEDx program ↗
        </a>
      </p>
    </section>

    <section class="mt-16 space-y-4 text-lg leading-relaxed text-neutral-700" aria-labelledby="about-ted-heading">
      <h2 id="about-ted-heading" class="text-2xl font-bold tracking-tight text-neutral-900">
        About TED
      </h2>
      <p>
        TED is a nonprofit, nonpartisan organization dedicated to discovering, debating and
        spreading ideas that spark conversation, deepen understanding and drive meaningful change.
        Our organization is devoted to curiosity, reason, wonder and the pursuit of knowledge —
        without an agenda. We welcome people from every discipline and culture who seek a deeper
        understanding of the world and connection with others, and we invite everyone to engage
        with ideas and activate them in your community.
      </p>
      <p>
        TED began in 1984 as a conference where Technology, Entertainment and Design converged, but
        today it spans a multitude of worldwide communities and initiatives exploring everything
        from science and business to education, arts and global issues. In addition to the TED
        Talks curated from our annual conferences and published on TED.com, we produce original
        podcasts, short video series, animated educational lessons (TED-Ed) and TV programs that
        are translated into more than 100 languages and distributed via partnerships around the
        world. Each year, thousands of independently run TEDx events. Through the Audacious
        Project, TED has helped catalyze $6.6 billion in funding for projects that support bold
        solutions to the world's most urgent challenges — working to make the world more
        beautiful, sustainable and just. In 2020, TED launched Countdown, an initiative to
        accelerate solutions to the climate crisis and mobilize a movement for a net-zero future,
        and in 2023 TED launched TED Democracy to spark a new kind of conversation focused on
        realistic pathways towards a more vibrant and equitable future.
      </p>
    </section>
  </article>
</BaseLayout>
