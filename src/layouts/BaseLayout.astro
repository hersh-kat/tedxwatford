---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EventSchema from '../components/EventSchema.astro';
import { eventInfo } from '../data/event';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  includeEventSchema?: boolean;
}

const {
  title = `${eventInfo.name} — ${eventInfo.tagline}`,
  description = eventInfo.description,
  pathname = '/',
  includeEventSchema = true,
} = Astro.props;

const canonical = new URL(pathname, eventInfo.siteUrl).toString();
const ogImage = new URL('/og.png', eventInfo.siteUrl).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eb0028" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={eventInfo.name} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {includeEventSchema && <EventSchema />}
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:shadow"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script id="luma-checkout" src="https://embed.lu.ma/checkout-button.js" defer></script>
  </body>
</html>
